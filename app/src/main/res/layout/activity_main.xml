<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Harry Potter API"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnCharacterById"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Personagem por ID"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnTeacher"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Professor"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnHouseStudents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Estudantes por Casa"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnSpells"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Feitiços"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnExit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sair" />

</LinearLayout>
