<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp">

    <FrameLayout
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:background="@drawable/crest_circle"
        android:layout_marginBottom="20dp">

        <ImageView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_wand"
            android:contentDescription="@null" />
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Harry Potter API"
        style="@style/Text.Hpapi.Title" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Explore o mundo bruxo"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="36dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCharacterById"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Personagem por ID"
        app:icon="@android:drawable/ic_menu_search"
        app:iconGravity="textStart"
        app:iconTint="@color/midnight_dark"
        android:layout_marginBottom="14dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCharactersList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Listar Personagens"
        app:icon="@android:drawable/ic_menu_agenda"
        app:iconGravity="textStart"
        app:iconTint="@color/midnight_dark"
        android:layout_marginBottom="14dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTeacher"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Professor"
        app:icon="@android:drawable/ic_menu_myplaces"
        app:iconGravity="textStart"
        app:iconTint="@color/midnight_dark"
        android:layout_marginBottom="14dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHouseStudents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Estudantes por Casa"
        app:icon="@android:drawable/ic_menu_sort_by_size"
        app:iconGravity="textStart"
        app:iconTint="@color/midnight_dark"
        android:layout_marginBottom="14dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSpells"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Feitiços"
        app:icon="@android:drawable/ic_menu_compass"
        app:iconGravity="textStart"
        app:iconTint="@color/midnight_dark"
        android:layout_marginBottom="14dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExit"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sair"
        android:textColor="@color/text_secondary"
        app:strokeColor="@color/divider"
        android:layout_marginTop="8dp" />

</LinearLayout>
