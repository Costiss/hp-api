<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Hpapi" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gold</item>
        <item name="colorOnPrimary">@color/midnight_dark</item>
        <item name="colorPrimaryContainer">@color/gold_dark</item>
        <item name="colorOnPrimaryContainer">@color/parchment</item>
        <item name="colorSecondary">@color/gold_light</item>
        <item name="colorOnSecondary">@color/midnight_dark</item>

        <item name="android:colorBackground">@color/midnight</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/divider</item>

        <item name="android:statusBarColor">@color/midnight_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="materialButtonStyle">@style/Widget.Hpapi.Button</item>
        <item name="textInputStyle">@style/Widget.Hpapi.TextInputLayout</item>
    </style>

    <style name="Widget.Hpapi.Button" parent="Widget.Material3.Button">
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/midnight_dark</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="cornerRadius">14dp</item>
        <item name="backgroundTint">@color/gold</item>
    </style>

    <style name="Widget.Hpapi.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/gold</item>
        <item name="hintTextColor">@color/gold_light</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="Widget.Hpapi.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Text.Hpapi.Title" parent="">
        <item name="android:textColor">@color/parchment</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:fontFamily">serif</item>
    </style>

    <style name="Text.Hpapi.SectionLabel" parent="">
        <item name="android:textColor">@color/gold_light</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>
